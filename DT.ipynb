# Part 3 — Decision Tree Regression

**الهدف:** بدل ما نتنبأ بالفئة (A/B/C/D)، هنتنبأ بقيمة رقمية وهي قفزة الشخص بالسنتيمتر
```
broad jump_cm
```
**نوع النموذج المستخدم:**
```
DecisionTreeRegressor
```
### تجهيز الداتا للريجريشن
from sklearn.tree import DecisionTreeRegressor
from sklearn.metrics import mean_absolute_error, mean_squared_error, r2_score

# الـ target دلوقتي رقم مش فئة
X_reg = df.drop(columns=['diastolic', 'systolic', 'class', 'broad jump_cm'])
y_reg = df['broad jump_cm']

print('Features shape:', X_reg.shape)
print('Target shape  :', y_reg.shape)
print('Target sample :', y_reg.head().values)

### تقسيم الداتا
X_reg_train, X_reg_test, y_reg_train, y_reg_test = train_test_split(
    X_reg, y_reg,
    test_size=0.2,
    random_state=42
)

print(f'Training samples : {len(X_reg_train)}')
print(f'Testing  samples : {len(X_reg_test)}')

### إيجاد أفضل عمق للشجرة
depths = range(2, 21)
train_r2 = []
test_r2  = []

for depth in depths:
    reg = DecisionTreeRegressor(max_depth=depth, random_state=42)
    reg.fit(X_reg_train, y_reg_train)
    train_r2.append(r2_score(y_reg_train, reg.predict(X_reg_train)))
    test_r2.append(r2_score(y_reg_test,   reg.predict(X_reg_test)))

best_reg_depth = list(depths)[test_r2.index(max(test_r2))]

plt.figure(figsize=(10, 5))
plt.plot(depths, train_r2, 'o-', label='Train R2', color='royalblue', linewidth=2)
plt.plot(depths, test_r2,  's-', label='Test  R2', color='tomato',    linewidth=2)
plt.axvline(x=best_reg_depth, color='green', linestyle='--', alpha=0.8)
plt.text(best_reg_depth + 0.2, min(train_r2), f'  Best Depth = {best_reg_depth}', color='green', fontsize=10)
plt.xlabel('Tree Depth (max_depth)', fontsize=12)
plt.ylabel('R2 Score', fontsize=12)
plt.title('Train vs Test R2 at Different Depths — Regression', fontsize=13)
plt.xticks(depths)
plt.legend(fontsize=11)
plt.grid(True, alpha=0.3)
plt.tight_layout()
plt.show()

print(f'Best Depth: {best_reg_depth}  =>  Test R2 = {max(test_r2):.4f}')

### تدريب النموذج النهائي
best_reg_model = DecisionTreeRegressor(
    max_depth=best_reg_depth,
    random_state=42
)

best_reg_model.fit(X_reg_train, y_reg_train)

print('Regression model trained!')
print(f'Tree Depth : {best_reg_model.get_depth()}')
print(f'Leaf Nodes : {best_reg_model.get_n_leaves()}')

### تقييم النموذج
y_reg_pred = best_reg_model.predict(X_reg_test)

mae  = mean_absolute_error(y_reg_test, y_reg_pred)
mse  = mean_squared_error(y_reg_test,  y_reg_pred)
rmse = mse ** 0.5
r2   = r2_score(y_reg_test,            y_reg_pred)

print('=' * 50)
print('      Regression Model Results')
print('=' * 50)
print(f'  MAE  (متوسط الخطأ)          : {mae:.2f} cm')
print(f'  RMSE (جذر متوسط مربع الخطأ) : {rmse:.2f} cm')
print(f'  R2   (دقة النموذج)          : {r2:.4f}  ({r2*100:.2f}%)')
print('=' * 50)

### مقارنة القيم الحقيقية بالمتوقعة
