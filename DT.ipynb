# Part 2 — Machine Learning Model Training

## Goal
Train and compare multiple ML models on the Body Performance dataset.

**Classification target:** `class` (A=1, B=2, C=3, D=4)  
**Regression target:** `broad jump_cm`

# 2) Decision Tree Model
###  Train / Test Split

- **80%**
- **20%**
X_train, X_test, y_train, y_test = train_test_split(
    X, y,
    test_size=0.2,      # 20% for testing
    random_state=42,    # For reproducibility
    stratify=y          # Balanced class distribution in train & test
)
depths = range(2, 21)
train_scores = []
test_scores  = []

for depth in depths:
    model = DecisionTreeClassifier(max_depth=depth, random_state=42)
    model.fit(X_train, y_train)
    train_scores.append(accuracy_score(y_train, model.predict(X_train)))
    test_scores.append(accuracy_score(y_test,  model.predict(X_test)))

# Best depth
best_depth = list(depths)[test_scores.index(max(test_scores))]

# Plot
plt.figure(figsize=(10, 5))
plt.plot(depths, train_scores, 'o-', label='Train Accuracy', color='royalblue', linewidth=2)
plt.plot(depths, test_scores,  's-', label='Test Accuracy',  color='tomato',    linewidth=2)
plt.axvline(x=best_depth, color='green', linestyle='--', alpha=0.8)
plt.text(best_depth + 0.2, min(train_scores), f'  Best Depth = {best_depth}', color='green', fontsize=10)
plt.xlabel('Tree Depth (max_depth)', fontsize=12)
plt.ylabel('Accuracy',        fontsize=12)
plt.title('Train vs Test Accuracy at Different Depths', fontsize=13)
plt.xticks(depths)
plt.legend(fontsize=11)
plt.grid(True, alpha=0.3)
plt.tight_layout()
plt.show()

print(f'\n Best depth: {best_depth}  →  Test Accuracy = {max(test_scores)*100:.2f}%')
###  Build Final Model
best_model = DecisionTreeClassifier(
    criterion='gini',     # Criterion for splitting at each node
    max_depth=best_depth, # Best depth found above (= 12)
    random_state=42
)

best_model.fit(X_train, y_train)

print(' Final model built and trained!')
print(f'   Tree Depth  : {best_model.get_depth()}')
print(f'   Leaf Nodes  : {best_model.get_n_leaves()}')
##  Evaluate the Model
y_pred = best_model.predict(X_test)

accuracy  = accuracy_score(y_test, y_pred)
precision = precision_score(y_test, y_pred, average='weighted')
recall    = recall_score(y_test, y_pred, average='weighted')
f1        = f1_score(y_test, y_pred, average='weighted')

print('=' * 50)
print('           Final Model Results')
print('=' * 50)
print(f'  Accuracy  : {accuracy:.4f}  ({accuracy*100:.2f}%)')
print(f'  Precision : {precision:.4f}  ({precision*100:.2f}%)')
print(f'  Recall    : {recall:.4f}  ({recall*100:.2f}%)')
