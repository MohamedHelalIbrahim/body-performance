for col in df.select_dtypes(include=['number']):
    skew_val = df[col].skew()

    if skew_val > 1:
        shape = "Highly Right-Skewed (Long Right Tail)"
    elif skew_val > 0.5:
        shape = "Moderately Right-Skewed"
    elif skew_val < -1:
        shape = "Highly Left-Skewed"
    elif skew_val < -0.5:
        shape = "Moderately Left-Skewed"
    else:
        shape = "Approximately Symmetric"

    plt.figure(figsize=(6, 3))
    sns.histplot(df[col], kde=True, color='Green')
    plt.title(f'Distribution of {col}')
    plt.figtext(0.5, -0.05, f'Skew: {skew_val:.2f} → {shape}',ha='center', fontsize=11, color='Green')
    plt.tight_layout()
    plt.show()
plt.figure(figsize=(20,6))
sns.boxplot(data=df)
plt.xticks(rotation=45)
plt.show()
#Apply the same outlier treatment to columns

for col in ['weight_kg', 'body fat_%', 'gripForce', 'broad jump_cm', 'height_cm']:
    Q1, Q3 = df[col].quantile([0.25, 0.75])
    IQR = Q3 - Q1
    df[col] = df[col].clip(Q1 - 1.5*IQR, Q3 + 1.5*IQR)

# replace outilers with mean values for systolic & Diastolic
for col in ['systolic', 'diastolic']:
    Q1 = df[col].quantile(0.25)
    Q3 = df[col].quantile(0.75)
    IQR = Q3 - Q1

    lower_bound = Q1 - 1.5 * IQR
    upper_bound = Q3 + 1.5 * IQR

    mean_val = df.loc[(df[col] >= lower_bound) & (df[col] <= upper_bound), col].mean()
    df.loc[(df[col] < lower_bound) | (df[col] > upper_bound), col] = mean_val
print("Outlier treatment complete.")

