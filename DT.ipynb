plt.scatter(y_reg_test, y_reg_pred, alpha=0.4, color='royalblue', edgecolors='white', linewidth=0.5)
plt.plot(
    [y_reg_test.min(), y_reg_test.max()],
    [y_reg_test.min(), y_reg_test.max()],
