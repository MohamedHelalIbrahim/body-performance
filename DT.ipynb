)
plt.xlabel('Actual broad jump (cm)',    fontsize=12)
plt.ylabel('Predicted broad jump (cm)', fontsize=12)
plt.title(f'Actual vs Predicted  (R2 = {r2:.2f})', fontsize=13)
plt.legend(fontsize=11)
plt.grid(True, alpha=0.3)
plt.tight_layout()
plt.show()

